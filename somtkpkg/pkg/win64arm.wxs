<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product Id="*" Name="somLite Toolkit" Language="1033" Version="1.0.0.0" Manufacturer="somfree.sf.net" UpgradeCode="68CFDB62-E366-4A3D-AA8B-9722D40B09E3">
    <Package InstallerVersion="200" Compressed="yes" InstallScope="perMachine" Platform="x64" Description="somLite Toolkit" Comments="object toolkit" />
    <MediaTemplate EmbedCab="yes" />
    <Feature Id="ProductFeature" Title="setup" Level="1">
      <ComponentGroupRef Id="ProductComponents" />
    </Feature>
    <Upgrade Id="{68CFDB62-E366-4A3D-AA8B-9722D40B09E3}">
      <UpgradeVersion Maximum="1.0.0.0" Property="OLDPRODUCTFOUND" OnlyDetect="no" IncludeMinimum="yes" IncludeMaximum="no" />
    </Upgrade>
    <InstallExecuteSequence>
      <RemoveExistingProducts After="InstallInitialize" />
    </InstallExecuteSequence>
    <Condition Message="This application is only supported on Windows 7 or higher."><![CDATA[Installed OR (VersionNT > 600)]]></Condition>
  </Product>
  <Fragment>
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="COMPANYDIR" Name="rhubarb-geek-nz">
          <Directory Id="INSTALLDIR" Name="somLite">
            <Directory Id="INSTALLDIR1" Name="bin" />
            <Directory Id="INSTALLDIR2" Name="lib" />
            <Directory Id="INSTALLDIR3" Name="include" />
          </Directory>
        </Directory>
      </Directory>
    </Directory>
  </Fragment>
  <Fragment>
    <ComponentGroup Id="ProductComponents">
      <Component Id="som.dll" Guid="*" Directory="INSTALLDIR1" Win64="yes" >
        <File Id="som.dll" KeyPath="yes" />
      </Component>
      <Component Id="somlite.lib" Guid="*" Directory="INSTALLDIR2" Win64="yes" >
        <File Id="som.lib" KeyPath="yes" />
      </Component>
      <Component Id="somobj.idl" Guid="*" Directory="INSTALLDIR3" Win64="yes" >
        <File Id="somobj.idl" KeyPath="yes" />
      </Component>
    </ComponentGroup>
  </Fragment>
</Wix>
